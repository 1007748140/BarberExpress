#No subir este archivo al repositorio de entorno de desarollo publico, ya que contiene las credenciales
#de la conexion de la base de datos.
PORT=5000

DB_HOST=localhost           # La dirección del servidor MySQL (puede ser localhost o una IP remota)
DB_USER=root                # El nombre de usuario de la base de datos MySQL
DB_PASSWORD=''    # en este caso no tiene contraseña
DB_NAME=barberexpress    # El nombre de la base de datos a la que te quieres conectar
